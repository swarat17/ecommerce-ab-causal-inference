# Database
DB_URL=postgresql://postgres:postgres@localhost:5432/ab_testing

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
S3_BUCKET=your-ab-testing-bucket

# SageMaker
SAGEMAKER_ROLE_ARN=arn:aws:iam::123456789:role/SageMakerRole
SAGEMAKER_MODEL_GROUP=ab-testing-propensity-models

# Data paths
RAW_DATA_PATH=data/raw/
PROCESSED_DATA_PATH=data/processed/
MODELS_PATH=models/
